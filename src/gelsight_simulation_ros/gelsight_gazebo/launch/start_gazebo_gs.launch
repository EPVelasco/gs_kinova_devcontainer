<launch>
  <!-- ============ ARGs ================= -->
  <arg name="use_sim_time" default="true"/>
  <arg name="debug" default="false" />
  <arg name="gui" default="true" />
  <arg name="paused" default="false" />
  <arg name="gs_sim" default="true" />
  <arg name="start_rviz" default="true" />
  
  <!-- Pose of object -->
  <arg name="object_name" default="aluminum_profile"/>
  <arg name="x" default="0.5"/>
  <arg name="y" default="0.5"/>
  <arg name="z" default="0.0"/>
  <arg name="roll" default="0.0"/>
  <arg name="pitch" default="0.0"/>
  <arg name="yaw" default="0.0"/>

  <!-- ============ STL Object ============ -->
  <node pkg="kortex_gazebo" type="generate_objects_world.py" name="generate_world_node" output="screen"
        args="$(arg object_name) $(arg x) $(arg y) $(arg z) $(arg roll) $(arg pitch) $(arg yaw)"/>

  <!-- Ruta al mundo generado dinámicamente -->
  <arg name="world_file" default="/tmp/generated_world.world"/>

  <!-- ============ SENSOR ============ -->
  <param name="robot_description" command="$(find xacro)/xacro '$(find gelsight_description)/urdf/gelsight_free.xacro'" />

  <!-- Publicadores de TF -->
  <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher" output="screen"/>
  <node pkg="joint_state_publisher" type="joint_state_publisher" name="joint_state_publisher" output="screen"/>

  <!-- ============ LAUNCH GAZEBO ============ -->
  <include file="$(find gazebo_ros)/launch/empty_world.launch">
    <arg name="world_name" value="$(arg world_file)" />
    <arg name="paused" value="$(arg paused)"/>
    <arg name="use_sim_time" value="$(arg use_sim_time)"/>
    <arg name="gui" value="$(arg gui)"/>
    <arg name="debug" value="$(arg debug)"/>
  </include>

  <!-- ============ SPAWN DEL SENSOR EN GAZEBO ============ -->
  <arg name="pi" default="3.1416" />
  <node name="spawn_gelsight" pkg="gazebo_ros" type="spawn_model" output="screen"
      args="-param robot_description -urdf -model gelsight_sensor -x 0.461190 -y 0.807081 -z 0.080191 -R $(arg pi) -P -0.843364 -Y 0" />
  <!-- Run gelsight_simulation -->
    <include file="$(find gelsight_simulation)/launch/gs_gel_link.launch" if="$(arg gs_sim)"/>

  <!-- Run rviz -->
  <node name="rviz" pkg="rviz" type="rviz" args="-d $(find gelsight_gazebo)/rviz/gs_rviz_test.rviz" if="$(arg start_rviz)" />

  <!-- RUN feature extractor and twist control -->
  <node pkg="gelsight_simulation" type="feature_extractor.py"        name="image_subscriber_publisher" output="screen" />
  <node pkg="gelsight_simulation" type="twist_control_free_body.py"  name="gs_twist_controller"        output="screen" />

</launch>
