Panels:
  - Class: rviz/Displays
    Help Height: 78
    Name: Displays
    Property Tree Widget:
      Expanded:
        - /pc_gs_deformation1/Autocompute Value Bounds1
      Splitter Ratio: 0.7323529124259949
    Tree Height: 473
  - Class: rviz/Selection
    Name: Selection
  - Class: rviz/Tool Properties
    Expanded:
      - /2D Pose Estimate1
      - /2D Nav Goal1
      - /Publish Point1
    Name: Tool Properties
    Splitter Ratio: 0.5886790156364441
  - Class: rviz/Views
    Expanded:
      - /Current View1
    Name: Views
    Splitter Ratio: 0.5
  - Class: rviz/Time
    Name: Time
    SyncMode: 0
    SyncSource: pc_gs_deformation
Preferences:
  PromptSaveOnExit: true
Toolbars:
  toolButtonStyle: 2
Visualization Manager:
  Class: ""
  Displays:
    - Alpha: 0.5
      Cell Size: 1
      Class: rviz/Grid
      Color: 160; 160; 164
      Enabled: true
      Line Style:
        Line Width: 0.029999999329447746
        Value: Lines
      Name: Grid
      Normal Cell Count: 0
      Offset:
        X: 0
        Y: 0
        Z: 0
      Plane: XY
      Plane Cell Count: 10
      Reference Frame: <Fixed Frame>
      Value: true
    - Alpha: 1
      Class: rviz/RobotModel
      Collision Enabled: false
      Enabled: true
      Links:
        All Links Enabled: true
        Expand Joint Details: false
        Expand Link Details: false
        Expand Tree: false
        Link Tree Style: Links in Alphabetic Order
        base_link:
          Alpha: 1
          Show Axes: false
          Show Trail: false
        gelsight_spectre_bottom:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        gelsight_spectre_left:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        gelsight_spectre_right:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        gelsight_spectre_top:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        gs_base_link:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        gs_camera_link:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        gs_camera_pcloud:
          Alpha: 1
          Show Axes: false
          Show Trail: false
        gs_cap_link:
          Alpha: 1
          Show Axes: false
          Show Trail: false
          Value: true
        gs_gel_link:
          Alpha: 1
          Show Axes: false
          Show Trail: false
      Name: RobotModel
      Robot Description: robot_description
      TF Prefix: ""
      Update Interval: 0
      Value: true
      Visual Enabled: true
    - Alpha: 1
      Class: rviz/Axes
      Enabled: true
      Length: 0.10000000149011612
      Name: world
      Radius: 0.019999999552965164
      Reference Frame: world
      Show Trail: false
      Value: true
    - Alpha: 0.30000001192092896
      Class: rviz/Axes
      Enabled: true
      Length: 0.029999999329447746
      Name: camera_link_gs_sensor
      Radius: 0.009999999776482582
      Reference Frame: gs_camera_pcloud
      Show Trail: false
      Value: true
    - Alpha: 1
      Class: rviz/Axes
      Enabled: true
      Length: 0.029999999329447746
      Name: base_link
      Radius: 0.0010000000474974513
      Reference Frame: base_link
      Show Trail: false
      Value: true
    - Class: rviz/TF
      Enabled: true
      Filter (blacklist): ""
      Filter (whitelist): ""
      Frame Timeout: 15
      Frames:
        All Enabled: false
        base_link:
          Value: true
        gelsight_spectre_bottom:
          Value: false
        gelsight_spectre_left:
          Value: false
        gelsight_spectre_right:
          Value: false
        gelsight_spectre_top:
          Value: false
        gs_base_link:
          Value: true
        gs_camera_link:
          Value: false
        gs_camera_pcloud:
          Value: false
        gs_cap_link:
          Value: false
        gs_gel_link:
          Value: false
        world:
          Value: true
      Marker Alpha: 1
      Marker Scale: 0.05000000074505806
      Name: TF
      Show Arrows: true
      Show Axes: true
      Show Names: true
      Tree:
        world:
          base_link:
            gs_camera_pcloud:
              gs_base_link:
                gelsight_spectre_bottom:
                  {}
                gelsight_spectre_left:
                  {}
                gelsight_spectre_right:
                  {}
                gelsight_spectre_top:
                  {}
                gs_camera_link:
                  {}
                gs_cap_link:
                  {}
                gs_gel_link:
                  {}
      Update Interval: 0
      Value: true
    - Class: rviz/Marker
      Enabled: true
      Marker Topic: /visualization_marker
      Name: object_and_gel_STL
      Namespaces:
        gs_gel: true
        objects: true
      Queue Size: 100
      Value: true
    - Alpha: 1
      Autocompute Intensity Bounds: true
      Autocompute Value Bounds:
        Max Value: 0.019999999552965164
        Min Value: 0.017999999225139618
        Value: false
      Axis: Z
      Channel Name: intensity
      Class: rviz/PointCloud2
      Color: 255; 255; 255
      Color Transformer: AxisColor
      Decay Time: 0
      Enabled: true
      Invert Rainbow: false
      Max Color: 255; 255; 255
      Min Color: 0; 0; 0
      Name: pc_gs_deformation
      Position Transformer: XYZ
      Queue Size: 10
      Selectable: true
      Size (Pixels): 1
      Size (m): 0.009999999776482582
      Style: Points
      Topic: /gelsight/depth/points
      Unreliable: false
      Use Fixed Frame: false
      Use rainbow: true
      Value: true
    - Class: rviz/Group
      Displays:
        - Class: rviz/Image
          Enabled: true
          Image Topic: /gelsight/image/image_raw
          Max Value: 1
          Median window: 5
          Min Value: 0
          Name: gs_camera_color
          Normalize Range: true
          Queue Size: 2
          Transport Hint: raw
          Unreliable: false
          Value: true
        - Class: rviz/Image
          Enabled: true
          Image Topic: /gelsight/tactile_image
          Max Value: 1
          Median window: 5
          Min Value: 0
          Name: gs_camera_simulated
          Normalize Range: true
          Queue Size: 2
          Transport Hint: raw
          Unreliable: false
          Value: true
        - Class: rviz/Image
          Enabled: true
          Image Topic: /gelsight/depth/image_raw
          Max Value: 1
          Median window: 5
          Min Value: 0
          Name: gs_camera_depth
          Normalize Range: true
          Queue Size: 2
          Transport Hint: raw
          Unreliable: false
          Value: true
        - Class: rviz/Image
          Enabled: true
          Image Topic: /gs_feature_img
          Max Value: 1
          Median window: 5
          Min Value: 0
          Name: gs_feature_extrator
          Normalize Range: true
          Queue Size: 2
          Transport Hint: raw
          Unreliable: false
          Value: true
      Enabled: true
      Name: images
  Enabled: true
  Global Options:
    Background Color: 48; 48; 48
    Default Light: true
    Fixed Frame: world
    Frame Rate: 30
  Name: root
  Tools:
    - Class: rviz/Interact
      Hide Inactive Objects: true
    - Class: rviz/MoveCamera
    - Class: rviz/Select
    - Class: rviz/FocusCamera
    - Class: rviz/Measure
    - Class: rviz/SetInitialPose
      Theta std deviation: 0.2617993950843811
      Topic: /initialpose
      X std deviation: 0.5
      Y std deviation: 0.5
    - Class: rviz/SetGoal
      Topic: /move_base_simple/goal
    - Class: rviz/PublishPoint
      Single click: true
      Topic: /clicked_point
  Value: true
  Views:
    Current:
      Class: rviz/Orbit
      Distance: 0.22558166086673737
      Enable Stereo Rendering:
        Stereo Eye Separation: 0.05999999865889549
        Stereo Focal Distance: 1
        Swap Stereo Eyes: false
        Value: false
      Field of View: 0.7853981852531433
      Focal Point:
        X: 0.5036544799804688
        Y: 0.7071892023086548
        Z: 0.006753844209015369
      Focal Shape Fixed Size: true
      Focal Shape Size: 0.0010000000474974513
      Invert Z Axis: false
      Name: Current View
      Near Clip Distance: 0.009999999776482582
      Pitch: 0.44979730248451233
      Target Frame: <Fixed Frame>
      Yaw: 0.62542724609375
    Saved: ~
Window Geometry:
  Displays:
    collapsed: true
  Height: 1013
  Hide Left Dock: true
  Hide Right Dock: true
  QMainWindow State: 
  Selection:
    collapsed: false
  Time:
    collapsed: false
  Tool Properties:
    collapsed: false
  Views:
    collapsed: true
  Width: 1680
  X: 0
  Y: 0
  gs_camera_color:
    collapsed: false
  gs_camera_depth:
    collapsed: false
  gs_camera_simulated:
    collapsed: false
  gs_feature_extrator:
    collapsed: false
