{
    "name": "gs_kinova",
    "privileged": true,
    "remoteUser": "epvs",
    "build": {
        "dockerfile": "Dockerfile",
        "args": {
            "USERNAME": "epvs"
        }
    },
    "workspaceFolder": "/home/catkin_ws",
    "workspaceMount": "source=${localWorkspaceFolder},target=/home/catkin_ws,type=bind",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-vscode.cpptools",
                "ms-vscode.cpptools-themes",
                "twxs.cmake",
                "donjayamanne.python-extension-pack",
                "eamodio.gitlens",
                "ms-iot.vscode-ros"
            ]
        }
    },
    "containerEnv": {
        "DISPLAY": "unix:0",
        "ROS_LOCALHOST_ONLY": "1",
        "ROS_DOMAIN_ID": "42"
    },
"runArgs": [
    "--gpus", "all",
    "--net=host",
    "--pid=host",
    "--ipc=host",
    "--cpuset-cpus=0-3",
    "-e", "NVIDIA_VISIBLE_DEVICES=all",
    "-e", "NVIDIA_DRIVER_CAPABILITIES=all",
    "-e", "DISPLAY=${env:DISPLAY}",
    "--device=/dev/input/js0"

]
,
    "mounts": [
        "source=/tmp/.X11-unix,target=/tmp/.X11-unix,type=bind,consistency=cached",
        "source=/dev/dri,target=/dev/dri,type=bind,consistency=cached"
    ],
    "postCreateCommand": "sudo chown -R $(whoami) /home/catkin_ws/"
}